{
    "AppSettings": {
        "ApiUrl": "http://localhost:5000/api",
        "AllowedHosts": "*"
    },
    "ConnectionStrings": {
        "DefaultConnection": "Server=.;Database=SafiStoreDb;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;"
    },
    "Jwt": {
        "AccessTokenExpiration": 15,
        "RefreshTokenExpiration": 30,
        "Secret": "REPLACE_WITH_ENV_VAR__Jwt__Secret__MIN_32_CHARS",
        "Issuer": "SafiStoreApi",
        "Audience": "SafiStoreClient"
    },
    "Cors": {
        "AllowedOrigins": [
            "http://localhost:4200",
            "http://localhost:4201"
        ]
    },
    "API": {
        "RequestTimeoutMs": 30000,
        "RetryDelayMs": 1000
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning"
        }
    }
}
