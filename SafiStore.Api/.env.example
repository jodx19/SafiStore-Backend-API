# Environment variables example for SafiStore.Api

# Application
APP_ENV=development
APP_URL=http://localhost:5000
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# Database (Postgres recommended)
# Example: Host=localhost;Port=5432;Database=safistore;Username=postgres;Password=postgres
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=safistore;Username=postgres;Password=postgres

# JWT
Jwt__Secret=your-very-strong-secret-at-least-32-chars
Jwt__Issuer=SafiStore
Jwt__Audience=SafiStoreUsers
Jwt__AccessTokenExpiration=15
Jwt__RefreshTokenExpiration=1440

# Stripe
STRIPE_KEY=sk_test_your_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Storage
STORAGE_PROVIDER=local # alternatives: s3, cloudinary
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Security
CORS__AllowedOrigins=http://localhost:4200
RATE_LIMIT__General__PermitPerMinute=60

# Other
LOG_LEVEL=Information

